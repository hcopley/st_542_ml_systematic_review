      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "# SuperLearner TI-IDF SVD (Heather, Jarrett, Andras)"
      ],
      "metadata": {
        "id": "jKO7-Mt5RPHs"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "## SuperLearner Ensemble"
      ],
      "metadata": {
        "id": "NWr0Fdj0R1v0"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "### 1. Overview\n",
        "Elastic‑net logistic regression (very strong baseline)\n",
        "Linear SVM\n",
        "XGBoost (low depth)\n",
        "Random forest (optional but weaker here)\n",
        "Naive Bayes (usually weak after SVD → often drop)"
      ],
      "metadata": {
        "id": "AQMmiz6rSGd0"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "### 2. Install packages and load data"
      ],
      "metadata": {
        "id": "s_XTkWxzRPFh"
      }
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "collapsed": true,
        "id": "-qaCKO83RM_6"
      },
      "outputs": [],
      "source": [
        "install.packages(c(\n",
        "  \"SuperLearner\",\n",
        "  \"glmnet\",\n",
        "  \"e1071\",\n",
        "  \"xgboost\",\n",
        "  \"randomForest\",\n",
        "  \"data.table\",\n",
        "  \"PRROC\",\n",
        "  \"pROC\"\n",
        "))"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# Load all required libraries after installation\n",
        "library(SuperLearner)\n",
        "library(glmnet) # Explicitly load glmnet\n",
        "library(e1071)  # For SL.svm (even if commented out in learners, good practice)\n",
        "library(xgboost)\n",
        "library(randomForest)\n",
        "library(data.table)\n",
        "library(PRROC)\n",
        "library(pROC)"
      ],
      "metadata": {
        "id": "sUqxy--4rYa7"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Load data\n",
        "dt <- readRDS(\"tfidf_svd_features.rds\")\n",
        "dt <- as.data.table(dt)"
      ],
      "metadata": {
        "id": "EyrK-KY9TZvR"
      },
      "execution_count": 9,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "3. Define outcome & predictors"
      ],
      "metadata": {
        "id": "_n0TZKcDTkA4"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Separate the response from features\n",
        "Y <- dt[[2]]\n",
        "X <- dt[, -c(1, 2), with = FALSE]"
      ],
      "metadata": {
        "id": "jEBJyprPToJo"
      },
      "execution_count": 10,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Check that the response is binary\n",
        "Y <- as.numeric(Y)"
      ],
      "metadata": {
        "id": "yrZ8-ruTT1PQ"
      },
      "execution_count": 11,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "### 4. Compute class weights (almost always necessary)"
      ],
      "metadata": {
        "id": "ImfWKvc9T2Tz"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Compute class weights\n",
        "pos_rate <- mean(Y == 1)\n",
        "neg_rate <- mean(Y == 0)\n",
        "\n",
        "# Assign inverse class frequency weights to balance the classes\n",
        "obs_weights <- ifelse(Y == 1, 1/pos_rate, 1/neg_rate)\n",
        "\n",
        "# This is crucial for screening recall."
      ],
      "metadata": {
        "id": "tz6LoeDeUY5Q"
      },
      "execution_count": 12,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "### 5. Define TF‑IDF‑optimized SuperLearner library"
      ],
      "metadata": {
        "id": "Nx4LYhBtVpYf"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Set learners' library\n",
        "learners <- c(\n",
        "  \"SL.glmnet\",        # Elastic‑net logistic (BEST for TF‑IDF)\n",
        "  #\"SL.svm\",           # Linear SVM\n",
        "  \"SL.xgboost\",       # Shallow boosted trees\n",
        "  \"SL.randomForest\"   # Optional, usually lower weight\n",
        "  #\"SL.naiveBayes\"     # Naive Bayes\n",
        ")"
      ],
      "metadata": {
        "id": "J25scV8AVs4f"
      },
      "execution_count": 14,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "### 6. Run 5‑fold SuperLearner cross‑validation\n"
      ],
      "metadata": {
        "id": "QVM2xmy2WFwD"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Run cross validation\n",
        "set.seed(542)\n",
        "\n",
        "sl_cv <- CV.SuperLearner(\n",
        "  Y = Y,\n",
        "  X = X,\n",
        "  SL.library = learners,\n",
        "  family = binomial(),\n",
        "  V = 5,\n",
        "  obsWeights = obs_weights,\n",
        "  method = \"method.NNLS\",\n",
        "  cvControl = list(stratifyCV = TRUE)\n",
        ")\n",
        "# Produces out‑of‑fold predictions. Prevents leakage. Suitable for reporting"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 505
        },
        "id": "bKzCZxP9WJjs",
        "outputId": "7d307521-015a-4c42-c480-99cdf291f25e"
      },
      "execution_count": 15,
      "outputs": [
       
    {
      "cell_type": "markdown",
      "source": [
        "### 7. Inspect ensemble weights"
      ],
      "metadata": {
        "id": "PyLFfmKTWrCj"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Print weights\n",
        "sl_cv$SL.weights\n",
        "\n",
        "# Typical TF‑IDF outcome: SL.glmnet: dominant. SL.svm: meaningful.\n",
        "# SL.xgboost: smaller but helpful. SL.randomForest: often near zero\n",
        "# This is expected and correct."
      ],
      "metadata": {
        "id": "cd7QIz7OWtdX"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "### 8. Evaluate PR‑AUC (preferred for screening)"
      ],
      "metadata": {
        "id": "rBrEEvr5XRnA"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Sketch PR Curve\n",
        "ibrary(PRROC)\n",
        "\n",
        "pr <- pr.curve(\n",
        "  scores.class0 = sl_cv$SL.predict[Y == 1],\n",
        "  scores.class1 = sl_cv$SL.predict[Y == 0],\n",
        "  curve = TRUE\n",
        ")\n",
        "\n",
        "pr$auc.integral"
      ],
      "metadata": {
        "id": "kFzGvY-SXU4U"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "### 9. Recall‑constrained threshold selection (screening‑ready)"
      ],
      "metadata": {
        "id": "pFGDbnpfXye4"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Search for recall selection (≥95% recall)\n",
        "target_recall <- 0.95\n",
        "threshold_grid <- seq(0.01, 0.6, by = 0.005)\n",
        "\n",
        "recalls <- sapply(threshold_grid, function(t) {\n",
        "  pred <- ifelse(sl_cv$SL.predict >= t, 1, 0)\n",
        "  sum(pred == 1 & Y == 1) / sum(Y == 1)\n",
        "})\n",
        "\n",
        "best_threshold <- min(threshold_grid[recalls >= target_recall])\n",
        "best_threshold"
      ],
      "metadata": {
        "id": "J4Xdue4DX0v7"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Workload reduction at that threshold (important result)\n",
        "pred_final <- ifelse(sl_cv$SL.predict >= best_threshold, 1, 0)\n",
        "workload_reduction <- 1 - mean(pred_final == 1)\n",
        "\n",
        "work"
      ],
      "metadata": {
        "id": "M8uINNiAYo9h"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "### 10. False negatives (must be audited)"
      ],
      "metadata": {
        "id": "ffeRmXkAZaP9"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Check false negatives\n",
        "false_negatives <- which(Y == 1 & pred_final == 0)\n",
        "length(false_negatives)"
      ],
      "metadata": {
        "id": "_ygcUOD9Zkx0"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "### 11. Final SuperLearner model (for deployment only)"
      ],
      "metadata": {
        "id": "Gl8uZzdjbPnT"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Set predict model\n",
        "final_sl <- SuperLearner(\n",
        "  Y = Y,\n",
        "  X = X,\n",
        "  SL.library = learners,\n",
        "  family = binomial(),\n",
        "  obsWeights = obs_weights,\n",
        "  method = \"method.NNLS\"\n",
        ")"
      ],
      "metadata": {
        "id": "uFLZuL0BbRIH"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "### 12. Prediction pipeline"
      ],
      "metadata": {
        "id": "GyvJdr_ce5AP"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "new_dt <- readRDS(\"tfidf_svd_features_new.rds\")\n",
        "X_new <- new_dt[, -c(1, 2), with = FALSE]\n",
        "\n",
        "pred_prob <- predict(\n",
        "  final_sl,\n",
        "  newdata = X_new,\n",
        "  onlySL = TRUE\n",
        ")$pred\n",
        "\n",
        "pred_label <- ifelse(pred_prob >= best_threshold, 1, 0)\n",
        "\n",
        "output <- data.table(\n",
        "  article_id = new_dt[[1]],\n",
        "  prob_include = pred_prob,\n",
        "  screen_in = pred_label\n",
        ")"
      ],
      "metadata": {
        "id": "MzrtMEE7e56Q"
      },
      "execution_count": null,
      "outputs": []
    }
  ]
}
